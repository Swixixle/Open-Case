# Copy to `.env` and fill in values. Never commit real secrets.

# --- Runtime mode ---
# Use production on Render etc. to enforce a real BASE_URL (crash if localhost).
ENV=development

# Skip adapter_cache reads (still writes fresh responses). Use while debugging APIs.
# BUST_CACHE=true

# --- Public deployment ---
# Absolute base URL for OG tags and receipt links (no trailing slash).
BASE_URL=http://localhost:8000

# --- External APIs ---
# Congress.gov (optional): member search, and name/state for Senate LIS vote matching.
# Senate votes themselves come from public Senate.gov XML — no key required.
CONGRESS_API_KEY=

# FEC Open Data (optional; defaults to DEMO_KEY with rate limits)
FEC_API_KEY=

# --- Cryptographic signing (Ed25519, base64 DER) ---
# Auto-generated on first run if absent; set both for stable keys across restarts.
OPEN_CASE_PRIVATE_KEY=
OPEN_CASE_PUBLIC_KEY=
