# Copy to `.env` and fill in values. Never commit real secrets.

# --- Runtime ---
# production: enforces non-localhost BASE_URL on startup
ENV=development

# --- HTTP / URLs ---
# Public site URL (no trailing slash). Required for production OG tags and receipt links.
BASE_URL=http://localhost:8000

# --- Database ---
# SQLite default when unset. Use postgres://... on Render etc.
DATABASE_URL=sqlite:///./open_case.db

# --- Signing (Ed25519 PKCS8/SPKI, base64 DER — see signing.py) ---
# Leave empty to auto-generate on first boot. Malformed/truncated base64 is detected at startup
# and replaced. To force a new pair: python3 scripts/regenerate_open_case_signing_keys.py
OPEN_CASE_PRIVATE_KEY=
OPEN_CASE_PUBLIC_KEY=

# --- Admin routes (credential file registration, entity resolution POST, etc.) ---
ADMIN_SECRET=

# --- Credential file fallback (optional; Render disk default) ---
# CREDENTIAL_DATA_DIR=/data/.credentials

# --- EthicalAlt proportionality API (optional; signals still work if unreachable) ---
PROPORTIONALITY_API_URL=https://ethicalalt-api.onrender.com
# Skip HTTP to EthicalAlt in CI/tests:
# SKIP_EXTERNAL_PROPORTIONALITY=1

# --- Adapter API keys (optional unless noted) ---
# FEC: optional; DEMO_KEY is public and rate-limited
FEC_API_KEY=
# Congress.gov via api.data.gov
CONGRESS_API_KEY=
# Regulations.gov
REGULATIONS_GOV_API_KEY=
# GovInfo collections / packages
GOVINFO_API_KEY=
# Required for enrichment layer — sonar model
PERPLEXITY_API_KEY=

# Optional: server-side story-angle assist (routes/assist.py) — tiered Gemini → Claude routing
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# ANTHROPIC_API_KEY=
# CLAUDE_MODEL=claude-sonnet-4-20250514

# Research routing (services/perplexity_router.py): phase-1 Gemini-first for some queries;
# phase-2 narrative prefers Claude when ANTHROPIC_API_KEY is set, then Perplexity Sonar, then Gemini.
# STAFF_NETWORK_TRY_GEMINI=1  # try Gemini before Perplexity for staff seed (default: Perplexity Sonar only)
# Reserved for future; Senate LDA is public without a key today
LDA_API_KEY=

# --- Public demo (batch senator cohort; no end-user API keys required) ---
# OPEN_CASE_PUBLIC_DEMO=1
# OPEN_CASE_DEMO_INVESTIGATOR_HANDLE=demo_public
# Extra browser origins for CORS (comma-separated), e.g. https://your-app.onrender.com
# OPEN_CASE_CORS_ORIGINS=https://open-case.onrender.com

# --- Debugging ---
# If true/1/yes: skip reading adapter HTTP cache (still writes fresh responses)
# BUST_CACHE=
