# API key for authenticated routes (senator dossier, PDF, story angles assist). Public verify route needs no key.
VITE_OPEN_CASE_API_KEY=

# Story angles: server route POST /api/v1/assist/story-angles uses GEMINI_API_KEY + ANTHROPIC_API_KEY in the API .env (tiered routing).

# Optional: override API origin (default same-origin in production, proxied /api in dev)
# VITE_OPEN_CASE_API_BASE=https://open-case.onrender.com
