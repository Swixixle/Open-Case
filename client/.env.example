# API key for authenticated routes (senator dossier, PDF). Public verify route needs no key.
VITE_OPEN_CASE_API_KEY=

# Optional: Story Angles section (Anthropic Messages API — client-side only).
VITE_ANTHROPIC_API_KEY=

# Optional: override API origin (default same-origin in production, proxied /api in dev)
# VITE_OPEN_CASE_API_BASE=https://open-case.onrender.com
