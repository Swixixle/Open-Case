# Copy to `.env.local` in this directory (same folder as package.json).
# `.env.local` is gitignored — never commit real keys.
#
# Restart the Vite dev server after changing env vars; Vite reads them at startup only.
#
# API key: create an investigator via POST /api/v1/auth/keys?handle=... (requires
# X-Admin-Secret / ADMIN_SECRET), or insert a hashed key in SQLite for local dev.

# Local FastAPI (default port 8000). Without this, apiUrl() uses same-origin /api and
# Vite's proxy may send traffic to the default remote in vite.config.js.
VITE_OPEN_CASE_API_BASE=http://127.0.0.1:8000

# Bearer token: open_case_<64 hex> — required for GET /api/v1/cases, /subjects/search, etc.
VITE_OPEN_CASE_API_KEY=
